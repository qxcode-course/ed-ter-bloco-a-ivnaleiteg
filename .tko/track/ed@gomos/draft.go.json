            "label": "2026-03-22_16-00-20",
            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tvar Q int\n\tvar dir string\n\n\tfmt.Scan(&Q, &dir)\n\n\tx := make([]int, Q)\n\ty := make([]int, Q)\n\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Scan(&x[i], &y[i])\n\t}\n\n\toldX := make([]int, Q)\n\toldY := make([]int, Q)\n\n\tcopy(oldX, x)\n\tcopy(oldY, y)\n\n\tswitch dir {\n\tcase \"L\":\n\t\tx[0]--\n\tcase \"R\":\n\t\tx[0]++\n\tcase \"U\":\n\t\ty[0]--\n\tcase \"D\":\n\t\ty[0]++\n\t}\n\n\tfor i := 1; i < Q; i++ {\n\t\tx[i] = oldX[i-1]\n\t\ty[i] = oldY[i-1]\n\t}\n\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Printf(\"%d %d\\n\", x[i],y[i])\n\t}\n}\n",
