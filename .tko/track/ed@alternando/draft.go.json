            "label": "2026-04-13_23-38-01",
            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n    var N, E, F int\n    fmt.Scan(&N, &E, &F)\n\n    vivos := make([]int, N)\n    valor := 1 \n\n    for i := 0; i < N; i++ {\n        if F == -1 {\n            valor = -(i + 1)\n            if i%2 == 1 {\n                valor = i + 1\n            }\n    \n        } else {\n            valor = i + 1\n            if i%2 == 1 {\n                valor = -(i + 1)\n            }\n        }\n        vivos[i] = valor \n    }\n    idx := E % len(vivos)\n\n    for len(vivos) > 1 {\n    \n        for i, v := range vivos {\n            if i == idx {\n                if v > 0 {\n                    fmt.Printf(\">%d \", v)\n                } else {\n                    fmt.Printf(\"<%d \", v)\n                }\n            } else {\n                fmt.Printf(\"%d \", v)\n            }\n        }\n        fmt.Println()\n\n        var alvo int\n        \n        if vivos[idx] > 0 {\n        } else {\n            alvo = (idx - 1 + len(vivos)) % len(vivos)\n        }\n\n        vivos = append(vivos[:alvo], vivos[alvo+1:]...)\n        \n        if idx >= len(vivos) {\n            idx = 0\n        }\n    }\n\n    fmt.Println(\"Vencedor:\", vivos[0])\n}\n",
